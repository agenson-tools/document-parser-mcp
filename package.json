{
  "name": "@agenson-horrowitz/document-parser-mcp",
  "version": "1.0.3",
  "description": "Multi-format document parser MCP server - extract text, tables, and metadata from PDFs, images, HTML, and office documents for AI agents",
  "main": "dist/index.js",
  "bin": {
    "document-parser-mcp": "dist/index.js"
  },
  "scripts": {
